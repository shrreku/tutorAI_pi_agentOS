# Docker Compose maps Postgres to host port 5433 (see repository root docker-compose.yml).
DATABASE_URL=postgres://studyagent:studyagent@127.0.0.1:5433/studyagent
API_PORT=4000
DEV_USER_EMAIL=dev@studyagent.local
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=studyagent-local
OBJECT_STORAGE_ACCESS_KEY=studyagent
OBJECT_STORAGE_SECRET_KEY=studyagent-local
OBJECT_STORAGE_REGION=us-east-1
REDIS_URL=redis://localhost:6379
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=studyagent-local
# Optional; worker projects concepts after LLM enrichment when Neo4j is reachable
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional; defaults to OPENROUTER_BASE_URL. OpenAI-compatible POST {base}/embeddings
EMBEDDING_API_BASE_URL=
DEFAULT_TUTOR_MODEL=openrouter/auto
DEFAULT_EXTRACTION_MODEL=openrouter/auto
GEMINI_API_KEY=
# Short name `gemini-embedding-2` maps to `google/gemini-embedding-2-preview` on OpenRouter
EMBEDDING_MODEL=gemini-embedding-2
EMBEDDING_DIMENSIONS=1536
LLAMAPARSE_API_KEY=
LLAMAPARSE_API_BASE_URL=https://api.cloud.llamaindex.ai
LLAMAPARSE_TIER=cost_effective
SESSION_SECRET=studyagent-local-session-secret
PUBLIC_API_BASE_URL=http://localhost:4000
LOG_LEVEL=info
ENABLE_DEV_TOOLS=true
ENABLE_LIVE_LLM_TESTS=false
DISABLE_AUTH=true
